---
import Base from "../layouts/Base.astro";
import CircuitCanvas from "../components/CircuitCanvas.tsx";
---
<Base title="LLM Circuits — Playground">
  <section class="mb-6">
    <h1 class="text-2xl font-bold" style="font-family: 'Chakra Petch', monospace;">Wire LLMs like resistors.</h1>
    <p class="mt-2 max-w-3xl text-stone-500 dark:text-stone-400">
      Pick a preset (2 LLMs in series, or 2 in parallel), drag in more "resistors" (each model has a mock resistance proportional to its parameter count), and apply current — your prompt — to run. Switch interpretation modes to see the same circuit behave differently.
    </p>
  </section>
  <CircuitCanvas client:only="react" />
</Base>
